<% layout('/layouts/boilerplate') %>

<div class="row justify-content-center">

<div class="col-md-5">

<div class="card shadow p-4">

<h2 class="text-center mb-4">
Login
</h2>

<form action="/login" method="POST">

<div class="mb-3">
<label>Email</label>

<input
type="email"
name="email"
class="form-control"
required>
</div>

<div class="mb-3">
<label>Password</label>

<input
type="password"
name="password"
class="form-control"
required>
</div>

<button
class="btn btn-primary w-100">

Login
</button>

</form>

<p class="mt-3 text-center">
No account?

<a href="/signup">
Signup
</a>
</p>

</div>
</div>
</div>
