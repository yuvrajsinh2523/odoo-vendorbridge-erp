<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0">

    <title>VendorBridge</title>

    <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">

    <link
    rel="stylesheet"
    href="/css/style.css">
</head>

<body>

<div class="d-flex">

    <!-- Sidebar -->

    <div class="sidebar">

    <h3 class="text-center mb-4">
        🏢 VendorBridge ERP
    </h3>

    <a href="/dashboard">
        Dashboard
    </a>


    <% if (
        user &&
        (
            user.role === "Admin" ||
            user.role ===
            "Procurement Officer"
        )
    ) { %>

        <a href="/vendors">
            Vendors
        </a>

        <a href="/rfq">
            RFQ
        </a>

    <% } %>


    <% if (
        user &&
        (
            user.role === "Admin" ||
            user.role === "Vendor" ||
            user.role ===
            "Procurement Officer"
        )
    ) { %>

        <a href="/quotations">
            Quotations
        </a>

    <% } %>


    <% if (
        user &&
        (
            user.role === "Admin" ||
            user.role === "Manager"
        )
    ) { %>

        <a href="/approvals">
            Approvals
        </a>

        <a href="/purchase-orders">
            Purchase Orders
        </a>

        <a href="/invoices">
            Invoices
        </a>

    <% } %>


    <% if (user) { %>

        <hr class="text-light">

        <p class="text-white">
            Logged in as:
            <strong>
                <%= user.role %>
            </strong>
        </p>

        <a
        href="/logout"
        class="text-danger">

            Logout
        </a>

    <% } %>

</div>


    <!-- Main Content -->

    <div class="content p-4">

        <%- body %>

    </div>

</div>

</body>
</html>
