<% layout('/layouts/boilerplate') %>

<h2>Create RFQ</h2>

<form
action="/rfq/new"
method="POST">

<div class="mb-3">
<label>RFQ Title</label>

<input
type="text"
name="title"
class="form-control"
required>
</div>


<div class="mb-3">
<label>Product Name</label>

<input
type="text"
name="product_name"
class="form-control"
required>
</div>


<div class="mb-3">
<label>Quantity</label>

<input
type="number"
name="quantity"
class="form-control"
required>
</div>


<div class="mb-3">
<label>Deadline</label>

<input
type="date"
name="deadline"
class="form-control"
required>
</div>


<div class="mb-3">
<label>Description</label>

<textarea
name="description"
class="form-control">
</textarea>
</div>


<div class="mb-3">
<label>Select Vendor</label>

<select
name="vendor_id"
class="form-control"
required>

<% vendors.forEach(vendor => { %>

<option
value="<%= vendor.id %>">

<%= vendor.vendor_name %>

</option>

<% }) %>

</select>
</div>


<button
class="btn btn-success">

Create RFQ
</button>

</form>
